rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() { return request.auth != null; }
    function role() { return signedIn() ? request.auth.token.role : null; }
    function isOps() { return role() in ['ops_agent', 'ops_approver', 'system']; }
    function isApprover() { return role() in ['ops_approver', 'system']; }
    function partnerId() { return signedIn() ? request.auth.token.partnerId : null; }

    function isCaseOwnerCase(caseId) {
      return signedIn() && get(/databases/$(database)/documents/cases/$(caseId)).data.ownerUid == request.auth.uid;
    }
    function isCasePartnerCase(caseId) {
      return signedIn()
        && partnerId() != null
        && get(/databases/$(database)/documents/cases/$(caseId)).data.partnerId == partnerId();
    }
    function canReadCaseById(caseId) { return isOps() || isCaseOwnerCase(caseId) || isCasePartnerCase(caseId); }

    // users
    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow create: if signedIn() && request.auth.uid == uid;
      allow update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    // partners (profile은 ops/partner admin만 수정 권장: 초기엔 ops 전용으로 잠금)
    match /partners/{pid} {
      allow read: if true; // 검색/결과 노출용(필요시 필드 분리/마스킹)
      allow write: if isOps(); // 초기 안전

      match /users/{uid} {
        allow read: if isOps() || (signedIn() && partnerId() == pid && request.auth.uid == uid);
        allow write: if isOps(); // partner 계정 관리는 ops에서만
      }

      match /receivables/{rid} {
        allow read: if isOps() || (signedIn() && partnerId() == pid);
        allow write: if isOps(); // 생성/상계는 정산 엔진(서버)만
      }
    }

    // sessions (비로그인 퍼널을 허용하는 경우 별도 키 전략 필요. v1은 로그인 기준)
    match /sessions/{sid} {
      allow read, write: if signedIn() && request.resource.data.ownerUid == request.auth.uid;
      match /events/{eid} {
        allow read, write: if signedIn(); // 디버그용(향후 제한)
      }
    }

    // cases
    match /cases/{caseId} {
      allow read: if isOps()
        || (signedIn() && resource.data.ownerUid == request.auth.uid)
        || (signedIn() && partnerId() != null && resource.data.partnerId == partnerId());

      // create는 Functions를 통해서만(클라 직접 생성 금지)
      allow create: if false;

      // 핵심 필드는 서버 전용(클라 직접 update 금지)
      allow update: if false;

      allow delete: if false;

      match /timeline/{eventId} {
        // 타임라인은 서버(Functions)만 작성
        allow read: if canReadCaseById(caseId);
        allow write: if isOps() || role() == 'system';
      }

      match /documents/{documentId} {
        // documents는 케이스 참여자만 read (collectionGroup 쿼리도 caseId 기반으로 판정)
        allow read: if canReadCaseById(caseId);
        // 문서 메타는 서버에서만 확정(클라 직접 write는 최소화)
        allow write: if isOps() || role() == 'system';
      }

      match /quotes/{quoteId} {
        allow read: if canReadCaseById(caseId);
        allow write: if isOps() || role() == 'system';
      }

      match /payments/{paymentId} {
        allow read: if canReadCaseById(caseId);
        allow write: if isOps() || role() == 'system';
      }

      match /refunds/{refundId} {
        allow read: if canReadCaseById(caseId);
        allow write: if isOps() || role() == 'system';
      }
    }

    // approvals (ops 전용)
    match /approvals/{approvalId} {
      allow read: if isOps();
      allow create: if isOps() || role() == 'system';
      allow update: if isApprover() || role() == 'system';
      allow delete: if false;
    }

    // settlements (ops write, partner read)
    match /settlements/{sid} {
      allow read: if isOps() || (signedIn() && partnerId() != null && resource.data.partnerId == partnerId());
      allow write: if isOps() || role() == 'system';
      allow delete: if false;
    }

    // auditLogs (ops 전용)
    match /auditLogs/{id} {
      allow read, write: if isOps() || role() == 'system';
    }
  }
}

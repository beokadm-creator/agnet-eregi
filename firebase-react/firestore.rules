rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 모든 데이터 접근은 Firebase Functions (Express API)를 통해서만 이루어집니다.
    // 클라이언트 측 Firebase SDK를 통한 직접적인 데이터베이스 읽기/쓰기를 전면 차단합니다.
    // 이는 가장 강력한 보안 모델인 "Server-Authoritative" 아키텍처를 강제합니다.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

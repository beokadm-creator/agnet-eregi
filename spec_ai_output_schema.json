{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AI Output Envelope Schema",
  "type": "object",
  "required": ["requestId", "caseId", "policyVersion", "timestamp", "confidence", "requiresHumanApproval", "outputs"],
  "properties": {
    "requestId": { "type": "string", "description": "UUID" },
    "caseId": { "type": "string" },
    "casePackId": { "type": ["string", "null"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "model": { "type": ["string", "null"] },
    "policyVersion": { "type": "string" },
    "confidence": { "type": "string", "enum": ["low", "medium", "high"] },
    "requiresHumanApproval": { "type": "boolean" },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "description": "근거(사건팩 규칙, 문서, 통계) 포인터",
      "items": {
        "type": "object",
        "required": ["type", "ref"],
        "properties": {
          "type": { "type": "string", "enum": ["casepack_rule", "document", "stats", "sop"] },
          "ref": { "type": "string" },
          "meta": { "type": "object" }
        }
      }
    },
    "outputs": {
      "type": "object",
      "properties": {
        "questionsToUser": {
          "type": "array",
          "items": { "type": "string" }
        },
        "missingDocumentSlots": {
          "type": "array",
          "items": { "type": "string" }
        },
        "documentSlotPrediction": {
          "type": "object",
          "properties": {
            "documentId": { "type": "string" },
            "predictedSlot": { "type": "string" },
            "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        },
        "inconsistencies": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "severity", "message"],
            "properties": {
              "type": { "type": "string" },
              "severity": { "type": "string", "enum": ["info", "warn", "critical"] },
              "message": { "type": "string" },
              "evidence": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "riskFlagsSuggested": {
          "type": "array",
          "items": { "type": "string" }
        },
        "fixRecommendations": {
          "type": "array",
          "items": { "type": "string" }
        },
        "messageDraft": {
          "type": "object",
          "required": ["channel", "text"],
          "properties": {
            "channel": { "type": "string", "enum": ["in_app", "email", "kakao", "sms"] },
            "text": { "type": "string" },
            "disclaimerIncluded": { "type": "boolean" }
          }
        },
        "priceRange": {
          "type": "object",
          "required": ["min", "max", "currency"],
          "properties": {
            "min": { "type": "number" },
            "max": { "type": "number" },
            "currency": { "type": "string", "default": "KRW" },
            "assumptions": { "type": "array", "items": { "type": "string" } }
          }
        },
        "priceBreakdown": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["component", "min", "max"],
            "properties": {
              "component": { "type": "string", "enum": ["LEGAL_FEES", "PROFESSIONAL_FEE", "PLATFORM_FEE", "ADDERS"] },
              "min": { "type": "number" },
              "max": { "type": "number" }
            }
          }
        },
        "etaRange": {
          "type": "object",
          "required": ["minHours", "maxHours"],
          "properties": {
            "minHours": { "type": "number" },
            "maxHours": { "type": "number" },
            "assumptions": { "type": "array", "items": { "type": "string" } }
          }
        }
      },
      "additionalProperties": true
    }
  }
}

